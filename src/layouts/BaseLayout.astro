---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';

interface Props {
  title: string;
  description: string;
  image?: string;
}

const { title, description, image } = Astro.props;
// FIX: Added optional chaining and a fallback to prevent "undefined" crashes
const currentPath = Astro.url?.pathname || '/';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} />
  </head>
  <body class="bg-[#0f1115] text-gray-200 font-sans">
    <div class="fixed inset-0 z-[-10] w-full h-full overflow-hidden">
      <img src="/assets/background.png" alt="Background Image" class="w-full h-full object-cover filter brightness-50" />
    </div>

    <Header currentPath={currentPath} />

    <main>
      <slot />
    </main>

    <Footer siteTitle={SITE_TITLE} />

  </body>
</html>
