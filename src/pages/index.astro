---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const whyMalloryItems = [
  {
    title: "Extension of your Company",
    body: "We understand that we are an extension of your company and represent and answer all queries of signers in a professional capacity.",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-accent"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a4.5 4.5 0 0 0 2.343-3.375M6.72 18.72a4.5 4.5 0 0 0-2.343-3.375m0 0V9.457m4.072 10.114a.75.75 0 0 1-.721-1.085L7.477 9.582m6.836 10.114a.75.75 0 0 0 .721-1.085l-1.389-7.527m0 0-.17-1.041A5.4 5.4 0 0 0 12 5.061V3a.75.75 0 0 0-.75-.75H6.75a.75.75 0 0 0-.75.75v1.277ZM17.25 9.457V5.06a5.4 5.4 0 0 0-1.705-3.952m-.102 9.017a.75.75 0 0 0 .721 1.085c.361-.194.67-.442.922-.727M12 14.004S17.25 10.5 17.25 10.5V5.062c0-1.084-.711-2.031-1.705-2.411M14.25 4.75h2.25M6 15.75h3.375c.591 0 .96-.51 1.14-.947l.502-1.125a1.125 1.125 0 0 1 1.74-.35h.001c.44-.06.848-.567.848-1.071 0-.511-.41-.992-.907-1.116l-1.477-.369M12 15.75S9.75 10.5 6 10.5V5.062c0-1.084.711-2.031 1.705-2.411H12M12 15.75a2.25 2.25 0 0 1 2.25 2.25M15.75 18H21C21.414 18 21.75 18.336 21.75 18.75c0 .243-.119.45-.304.576C20.26 20.457 17.5 21 12 21s-8.26-1.543-9.446-2.674C2.369 19.2 2.25 18.993 2.25 18.75 2.25 18.336 2.586 18 3 18H8.25m0 0a4.5 4.5 0 0 1 1.89-1.106M12 18a2.25 2.25 0 0 0 2.25-2.25V12a.75.75 0 0 0-.75-.75h-3.75a.75.75 0 0 0-.75.75v3.75c0 1.24.872 2.25 2.062 2.25H12Z" /> </svg>`,
  },
  {
    title: "NNA & LSS Certified",
    body: "I have undertaken NNA certifications, LSS certifications, and we are background screened and E&O insured.",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-accent"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>`,
  },
  {
    title: "Same-Day Delivery",
    body: "We understand the need for same-day delivery and FedEx the documents before the cutoff time.",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-accent"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375M21.75 12a2.25 2.25 0 0 0-2.25-2.25h-5.378c-.552 0-1.077.23-1.462.63l-4.474 4.475a1.5 1.5 0 0 0-.419 1.026V18a1.5 1.5 0 0 0 1.5 1.5h2.25m-1.5-3 1.5 1.5m-1.5-1.5 1.5-1.5M15.75 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0Z" /></svg>`,
  },
  {
    title: "Punctual & Professional Communication",
    body: "We arrive on-time every closing and keep communications open and responsive. Signers are reminded about appointments via our modern tech workflow.",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-accent"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>`,
  },
  {
    title: "Scanbacks",
    body: "We offer scanback services, ensuring swift document processing and client satisfaction. This streamlined approach enhances efficiency and peace of mind.",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-accent"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375H12c-1.036 0-1.036 1.5 0 1.5h4.125a1.875 1.875 0 0 1 0 3.75H12c-1.036 0-1.036 1.5 0 1.5h4.125c.621 0 1.125.504 1.125 1.125v1.5m-6-6h.008v.008H13.5v-.008Zm0 2.25h.008v.008H13.5V16.5Z" /></svg>`,
  },
  {
    title: "Responsive Communication",
    body: "We understand the importance of ensuring everything is signed to avoid funding issues, and we stay in open communication to quickly resolve any issues.",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-accent"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H6.75A2.25 2.25 0 0 0 4.5 14.25v2.25M8.625 12H12m0 0h3.375M12 12V6.75V4.5m-1.5 0h-.975m2.25 0H21M12 7.5v3.75m-3.75-3.75H12m5.25 0H21m-6 2.25a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm-3.75 0H7.5V10.5m10.5-3.75H15M4.5 16.5V18a2.25 2.25 0 0 0 2.25 2.25h10.5A2.25 2.25 0 0 0 21 18v-1.5m-4.125-6.75h-.008v.008h.008v-.008Zm0 2.25h-.008v.008h.008v-.008Zm-2.25 0h-.008v.008h.008v-.008Z" /></svg>`,
  },
];

const services = [
  {
    title: "Buyer Packages",
    body: "Expert in facilitating seamless transactions, offering comprehensive buyer packages and efficient notarization services to ensure peace of mind and legal compliance.",
  },
  {
    title: "Refinance Packages",
    body: "We validate mortgage, refinance, and HELOC documents for seamless loan transactions.",
  },
  {
    title: "Power of Attorney and Affidavits",
    body: "Empowering individuals with the legal authority to act on their behalf, offering comprehensive guidance and seamless execution of power of attorney documents.",
  },
  {
    title: "HELOC and Reverse Mortgages",
    body: "Specializing in HELOC and reverse mortgages, providing expert guidance and personalized solutions to empower clients in leveraging their home equity for financial freedom and security.",
  },
  {
    title: "Business Contract Notarization",
    body: "Your trusted partner in business contract notarization, ensuring legal compliance and peace of mind with meticulous attention to detail and seamless execution.",
  },
  {
    title: "Apostille and Document Translations",
    body: "Offering reliable apostille and certified document translation services, ensuring your legal, personal, and business documents are accurately authenticated and accepted worldwide with professionalism and efficiency.",
  },
];
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>

  <!-- ── HERO ── -->
  <section
    class="relative min-h-[90vh] flex items-center justify-center text-white overflow-hidden"
  >
    <!-- Background image with overlay -->
    <div
      class="absolute inset-0 bg-cover bg-center transition-transform duration-500 hover:scale-105"
      style="background-image:url('/assets/background.png');"
      aria-hidden="true"
    ></div>
    <div class="absolute inset-0 bg-primary opacity-80" aria-hidden="true"></div>

    <div class="relative z-10 text-center px-6 max-w-4xl mx-auto py-16">
      <p class="font-sans text-lg md:text-xl text-accent mb-4 tracking-wide uppercase">Premium Loan Signing Services</p>
      <h1 class="font-serif text-5xl md:text-7xl font-bold leading-tight mb-6 text-white">
        Your Trusted Partner for <br /> Precision Loan Signings
      </h1>
      <p class="text-lg md:text-xl text-gray-300 mt-4 mb-10 max-w-2xl mx-auto">
        Exemplary loan signing company dedicated to precision, professionalism, and client satisfaction.
      </p>
      <a
        href="/contact"
        class="inline-block bg-accent text-primary font-sans font-semibold text-base tracking-wider uppercase px-10 py-5 rounded-full hover:bg-opacity-90 transition-all duration-300 no-underline shadow-lg transform hover:scale-105"
      >
        Schedule a Signing
      </a>
    </div>
  </section>

  <!-- ── WHY MALLORY (Feature Grid) ── -->
  <section class="bg-primary py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="font-sans text-sm text-accent mb-2 tracking-widest uppercase">Our Commitment</p>
        <h2 class="font-serif text-4xl md:text-5xl text-white mt-2 mb-4">Why Choose Us</h2>
        <div class="h-1 w-24 bg-accent mx-auto rounded-full"></div>
        <p class="text-gray-300 max-w-2xl mx-auto mt-6 text-lg">
          I represent you at the closing table, going above and beyond for our clients.
          Here are some of our unique qualities.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {whyMalloryItems.map((item) => (
          <div class="bg-gray-800 border border-gray-700 p-8 rounded-lg shadow-xl card-lift hover:border-accent group">
            <div class="mb-4 transition-transform group-hover:scale-110">
              {item.svg && <Fragment set:html={item.svg} />}
            </div>
            <h3 class="font-serif text-2xl text-white mb-3 group-hover:text-accent transition-colors">{item.title}</h3>
            <p class="text-gray-400 text-base leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Trust Bar (Credentials) ── -->
  <section class="bg-gray-900 py-12 px-6 border-t border-b border-gray-700">
    <div class="max-w-6xl mx-auto text-center">
      <h2 class="font-serif text-3xl text-white mb-8">Trusted by Leading Companies</h2>
      <div class="flex flex-wrap justify-center items-center gap-10 md:gap-16 opacity-75">
        <!-- NNA Logo Placeholder -->
        <img src="/assets/nna-logo.png" alt="NNA Certified" class="h-16 filter grayscale hover:grayscale-0 transition-all duration-300" />
        <!-- LSS Logo Placeholder -->
        <img src="/assets/lss-logo.png" alt="LSS Certified" class="h-16 filter grayscale hover:grayscale-0 transition-all duration-300" />
        <!-- Add more logos as needed -->
      </div>
    </div>
  </section>

  <!-- ── OUR SERVICES ── -->
  <section class="bg-primary py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="font-sans text-sm text-accent mb-2 tracking-widest uppercase">What We Offer</p>
        <h2 class="font-serif text-4xl md:text-5xl text-white mt-2 mb-4">Our Services</h2>
        <div class="h-1 w-24 bg-accent mx-auto rounded-full"></div>
        <p class="text-gray-300 max-w-2xl mx-auto mt-6 text-lg">
          Our assurance of seamless notarial services. Trust us to safeguard your documents
          with precision and professionalism.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {services.map((service) => (
          <div class="bg-gray-800 border border-gray-700 p-8 rounded-lg shadow-xl card-lift hover:border-accent group">
            <h3 class="font-serif text-2xl text-white mb-3 group-hover:text-accent transition-colors">{service.title}</h3>
            <p class="text-gray-400 text-base leading-relaxed">{service.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CONTACT BANNER ── -->
  <section
    class="relative py-24 px-6 text-white text-center"
  >
    <div
      class="absolute inset-0 bg-cover bg-center opacity-20"
      style="background-image:url('/images/contact-banner.jpg');"
      aria-hidden="true"
    ></div>
    <div class="relative z-10 max-w-2xl mx-auto">
      <p class="font-sans text-sm text-accent mb-4 tracking-widest uppercase">Ready to Get Started?</p>
      <h2 class="font-serif text-4xl md:text-5xl mb-4">Let's Work Together</h2>
      <div class="h-1 w-24 bg-accent mx-auto rounded-full"></div>
      <p class="text-gray-300 mt-6 mb-10 text-lg">
        Contact us today to schedule your signing appointment or to learn more
        about how we can serve your title company, escrow office, or lending team.
      </p>
      <a
        href="/contact"
        class="inline-block border-2 border-accent text-accent font-sans font-semibold text-base tracking-wider uppercase px-10 py-5 rounded-full hover:bg-accent hover:text-primary transition-colors duration-300 no-underline shadow-lg transform hover:scale-105"
      >
        Contact Mallory
      </a>
    </div>
  </section>

</BaseLayout>
