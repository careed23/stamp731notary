---
import Layout from '../layouts/BaseLayout.astro';
const title = "Stamp 731 Notary | Premium Loan Signing Services";
---

<Layout title={title}>
  <nav class="sticky top-0 z-50 bg-[#0f1115]/80 backdrop-blur-md border-b border-white/10 py-4 px-6">
    <div class="max-w-6xl mx-auto flex justify-between items-center">
      <span class="text-[#D4AF37] font-bold text-xl tracking-tighter">STAMP 731</span>
      <div class="space-x-6 text-sm font-medium text-gray-300">
        <a href="/" class="hover:text-[#D4AF37] transition">Home</a>
        <a href="/about" class="hover:text-[#D4AF37] transition">About</a>
        <a href="#contact" class="bg-[#D4AF37] text-black px-4 py-2 rounded shadow-lg hover:bg-yellow-600 transition">Contact</a>
      </div>
    </div>
  </nav>
  
    <div class="relative z-10">
        <section class="text-white pt-32 pb-20 px-6 text-center">
    <p class="section-label">Milan, Tennessee & Surrounding Areas</p>
    <div class="gold-rule"></div>
    <h1 class="text-5xl md:text-7xl font-bold mb-6 tracking-tight">Premium Loan <br/><span class="text-[#D4AF37]">Signing Services</span></h1>
    <p class="max-w-2xl mx-auto text-gray-400 text-lg mb-10 leading-relaxed">
      Certified, Insured, and Reliable. We bridge the gap between title companies and signers with meticulous attention to detail.
    </p>
    <div class="flex justify-center gap-4">
      <a href="#contact" class="bg-[#D4AF37] text-black px-8 py-4 rounded-full font-bold text-lg hover:scale-105 transition-transform shadow-[0_0_20px_rgba(212,175,55,0.3)]">
        Schedule Now
      </a>
    </div>
  </section>

  <section class="py-24 bg-white px-6">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-3 gap-10">
        <div class="p-8 border border-gray-100 rounded-2xl card-lift bg-gray-50/50">
          <div class="w-12 h-12 bg-[#D4AF37]/10 flex items-center justify-center rounded-lg mb-6">
            <span class="text-[#D4AF37] text-2xl font-bold">✓</span>
          </div>
          <h3 class="font-bold text-xl mb-3 text-gray-900">Certified & Screened</h3>
          <p class="text-gray-600 text-sm leading-relaxed">NNA and LSS certifications held. Background screened annually and E&O insured for $100k+.</p>
        </div>
        <div class="p-8 border border-gray-100 rounded-2xl card-lift bg-gray-50/50">
           <div class="w-12 h-12 bg-[#D4AF37]/10 flex items-center justify-center rounded-lg mb-6 text-[#D4AF37]">🚚</div>
          <h3 class="font-bold text-xl mb-3 text-gray-900">Same-Day Delivery</h3>
          <p class="text-gray-600 text-sm leading-relaxed">We understand the importance of funding dates. All documents are dropped at FedEx/UPS before cutoff.</p>
        </div>
        <div class="p-8 border border-gray-100 rounded-2xl card-lift bg-gray-50/50">
           <div class="w-12 h-12 bg-[#D4AF37]/10 flex items-center justify-center rounded-lg mb-6 text-[#D4AF37]">💬</div>
          <h3 class="font-bold text-xl mb-3 text-gray-900">Responsive Comms</h3>
          <p class="text-gray-600 text-sm leading-relaxed">Modern tech-forward workflow. We keep you and the signers updated every step of the way.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
