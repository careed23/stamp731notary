---
interface Props {
  siteTitle: string;
}

const { siteTitle } = Astro.props;

// Safe check for the current path to avoid the build crash
const currentPath = Astro.url?.pathname ?? '/';

const navLinks = [
  { name: "Home", href: "/" },
  { name: "About", href: "/about" },
  { name: "Services", href: "#services" }, 
  { name: "Contact", href: "#contact" },
];
---

<footer class="bg-[#0f1115] text-gray-200 py-12 px-6 border-t border-white/5">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-8">
    
    <div class="text-center md:text-left">
      <p class="font-bold text-xl text-[#D4AF37] mb-1 tracking-tight">{siteTitle}</p>
      <p class="text-xs uppercase tracking-widest text-gray-500">Precision & Professionalism</p>
    </div>

    <ul class="flex flex-wrap justify-center gap-8 list-none m-0 p-0">
      {
        navLinks.map((link) => (
          <li>
            <a 
              href={link.href} 
              class={`text-sm tracking-wide transition-colors ${currentPath === link.href ? 'text-[#D4AF37]' : 'text-gray-400 hover:text-[#D4AF37]'}`}
            >
              {link.name}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="text-center md:text-right">
      <p class="text-[10px] uppercase tracking-widest text-gray-600 mb-2">Milan, Tennessee</p>
      <p class="text-xs text-gray-500">&copy; {new Date().getFullYear()} {siteTitle}.</p>
    </div>
  </div>
</footer>
