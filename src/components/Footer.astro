---
interface Props {
  siteTitle: string;
}

const { siteTitle } = Astro.props;

// Safe fallback for the URL
const currentPath = Astro.url?.pathname || '/';

const navLinks = [
  { name: "Home", href: "/" },
  { name: "About", href: "/about" },
  { name: "Services", href: "/services" },
  { name: "Contact", href: "/contact" },
];
---

<footer class="bg-[#0f1115] text-gray-200 py-12 px-6 border-t border-white/5">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
    <div class="text-center md:text-left">
      <p class="font-bold text-xl text-[#D4AF37] mb-1">{siteTitle}</p>
      <p class="text-sm text-gray-400">Exemplary Loan Signing — Precision & Professionalism</p>
    </div>
    
    <ul class="flex flex-wrap justify-center md:justify-start gap-6 list-none m-0 p-0">
      {
        navLinks.map((link) => {
          // Explicitly safe check
          const isActive = currentPath === link.href;
          
          return (
            <li>
              <a 
                href={link.href} 
                class={`text-sm transition-colors ${isActive ? 'text-[#D4AF37]' : 'text-gray-400 hover:text-[#D4AF37]'}`}
              >
                {link.name}
              </a>
            </li>
          );
        })
      }
    </ul>
    
    <p class="text-xs text-gray-500 text-center md:text-right">
      &copy; {new Date().getFullYear()} {siteTitle}. All rights reserved.
    </p>
  </div>
</footer>
