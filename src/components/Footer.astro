---
interface Props {
  siteTitle: string;
}

const { siteTitle } = Astro.props;

const navLinks = [
  { name: "Home", href: "/" },
  { name: "About", href: "/about" },
  { name: "Services", href: "/services" }, // Assuming a new services page
  { name: "Contact", href: "/contact" },
];
---

<footer class="bg-primary text-gray-200 py-12 px-6">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
    <div class="text-center md:text-left">
      <p class="font-serif text-lg text-accent mb-1">{siteTitle}</p>
      <p class="text-sm text-gray-400">Exemplary Loan Signing — Precision & Professionalism</p>
    </div>
    <ul class="flex flex-wrap justify-center md:justify-start gap-6 list-none m-0 p-0">
      {
        navLinks.map((link) => (
          <li>
            <a href={link.href} class="text-sm text-gray-400 hover:text-accent no-underline transition-colors">{link.name}</a>
          </li>
        ))
      }
    </ul>
    <p class="text-xs text-gray-500 text-center md:text-right">&copy; {new Date().getFullYear()} {siteTitle}. All rights reserved.</p>
  </div>
</footer>
